{
  "name": "ai-engineering-harness",
  "version": "0.1.0",
  "description": "A lightweight TypeScript engineering scaffold for small AI-assisted software projects.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haoranzhang929/ai-engineering-harness.git"
  },
  "bugs": {
    "url": "https://github.com/haoranzhang929/ai-engineering-harness/issues"
  },
  "homepage": "https://github.com/haoranzhang929/ai-engineering-harness#readme",
  "packageManager": "npm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx examples/run-example.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
